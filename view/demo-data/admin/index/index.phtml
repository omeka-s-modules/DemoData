<?php
$this->headTitle('Demo Data');
$this->headLink()->appendStylesheet($this->assetUrl('css/demo-data.css', 'DemoData'));
echo $this->pageTitle('Demo Data');
$csrf = new \Laminas\Form\Element\Csrf('demo_data_csrf');
$csrfValue = $csrf->getValue();
?>

<div id="demo-data-datasets">
<?php foreach ($datasets as $dataset): ?>
<div class="demo-data-item">
    <div class="demo-data-dataset">
        <div class="demo-data-dataset-header">
            <h2><?php echo $this->escapeHtml($dataset['label']); ?></h2>
            <?php if ($dataset['pending_action']): ?>
            <span class="demo-data-status in-progress">
                <?php echo $dataset['pending_action'] === 'purge'
                    ? $this->translate('Purging…')
                    : $this->translate('Importing…'); ?>
            </span>
            <?php elseif ($dataset['job_failed']): ?>
            <span class="demo-data-status failed">
                <?php echo $this->translate('Job failed'); ?>
            </span>
            <?php elseif ($dataset['imported']): ?>
            <span class="demo-data-status imported">
                <?php echo $this->translate('Imported'); ?>
            </span>
            <?php else: ?>
            <span class="demo-data-status not-imported">
                <?php echo $this->translate('Not imported'); ?>
            </span>
            <?php endif; ?>
        </div>

        <p><?php echo $this->escapeHtml($dataset['description']); ?></p>

        <p class="demo-data-meta">
            <?php echo sprintf(
                $this->translate('%d items &middot; %d item sets &middot; media included'),
                $dataset['item_count'],
                $dataset['set_count']
            ); ?>
        </p>

        <?php if ($dataset['main_item_set_id']): ?>
        <p><?php echo $this->hyperlink(
            $this->translate('Browse items'),
            $this->url('admin/default', ['controller' => 'item', 'action' => 'browse'], ['query' => ['item_set_id' => $dataset['main_item_set_id']]]),
            ['aria-label' => sprintf($this->translate('Browse items in %s'), $dataset['label'])]
        ); ?> &middot; <?php echo $this->hyperlink(
            $this->translate('Browse item sets'),
            $this->url('admin/default', ['controller' => 'item-set', 'action' => 'browse'], ['query' => ['id' => $dataset['item_set_ids']]]),
            ['aria-label' => sprintf($this->translate('Browse item sets in %s'), $dataset['label'])]
        ); ?></p>
        <?php endif; ?>

        <?php if ($dataset['view_job_id']): ?>
        <p><?php echo $this->hyperlink(
            $this->translate('View job'),
            $this->url('admin/id', ['controller' => 'job', 'action' => 'show', 'id' => $dataset['view_job_id']]),
            ['aria-label' => sprintf($this->translate('View job for %s'), $dataset['label']), 'target' => '_blank']
        ); ?> &middot; <?php echo $this->hyperlink(
            $this->translate('View log'),
            $this->url('admin/id', ['controller' => 'job', 'action' => 'log', 'id' => $dataset['view_job_id']]),
            ['aria-label' => sprintf($this->translate('View log for %s'), $dataset['label']), 'target' => '_blank']
        ); ?></p>
        <?php endif; ?>

        <?php if (!$dataset['pending_action']): ?>
        <div class="demo-data-actions">
            <form method="POST" action="<?php echo $this->escapeHtmlAttr($this->url('admin/demo-data')); ?>">
                <input type="hidden" name="csrf" value="<?php echo $this->escapeHtmlAttr($csrfValue); ?>">
                <input type="hidden" name="dataset" value="<?php echo $this->escapeHtmlAttr($dataset['name']); ?>">
                <input type="hidden" name="action" value="import">
                <button type="submit" class="button" aria-label="<?php echo $this->escapeHtmlAttr($dataset['imported'] ? sprintf($this->translate('Re-import %s'), $dataset['label']) : sprintf($this->translate('Import %s'), $dataset['label'])); ?>"<?php if ($dataset['imported']): ?> onclick="return confirm('<?php echo $this->escapeJs($this->translate('This will delete all imported items and re-import from scratch. Continue?')); ?>')"<?php endif; ?>><?php echo $dataset['imported'] ? $this->translate('Re-import') : $this->translate('Import'); ?></button>
            </form>
            <?php if ($dataset['imported']): ?>
            <form method="POST" action="<?php echo $this->escapeHtmlAttr($this->url('admin/demo-data')); ?>">
                <input type="hidden" name="csrf" value="<?php echo $this->escapeHtmlAttr($csrfValue); ?>">
                <input type="hidden" name="dataset" value="<?php echo $this->escapeHtmlAttr($dataset['name']); ?>">
                <input type="hidden" name="action" value="purge">
                <button type="submit" class="button" aria-label="<?php echo $this->escapeHtmlAttr(sprintf($this->translate('Purge %s'), $dataset['label'])); ?>" onclick="return confirm('<?php echo $this->escapeJs($this->translate('This will delete all imported items. Continue?')); ?>')"><span class="o-icon-delete" aria-hidden="true"></span><?php echo $this->translate('Purge'); ?></button>
            </form>
            <?php endif; ?>
        </div>
        <?php endif; ?>
    </div>
</div>
<?php endforeach; ?>
</div>
